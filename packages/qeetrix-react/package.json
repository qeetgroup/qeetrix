{
  "name": "@qeetrix/react",
  "private": false,
  "version": "0.0.1",
  "description": "Qeetrix React components and shared styles.",
  "keywords": [
    "qeetrix",
    "react",
    "components",
    "design-system"
  ],
  "homepage": "https://github.com/qeetgroup/qeetrix/tree/main/packages/qeetrix-react#readme",
  "bugs": {
    "url": "https://github.com/qeetgroup/qeetrix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qeetgroup/qeetrix.git",
    "directory": "packages/qeetrix-react"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && pnpm run build:js && pnpm run build:types",
    "build:demo": "vite build --outDir dist-demo",
    "build:js": "vite build --config vite.config.lib.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "pack": "pnpm run build && npm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@qeetrix/eslint": "workspace:*",
    "@qeetrix/icons": "workspace:*",
    "@qeetrix/tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
