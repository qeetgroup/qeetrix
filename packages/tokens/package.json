{
  "name": "@qeetrix/tokens",
  "version": "0.0.1",
  "private": false,
  "description": "Qeetrix design tokens — single W3C source built to CSS + JSON via Style Dictionary.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": ["*.css"],
  "files": ["dist"],
  "exports": {
    "./qeetrix.css": "./dist/qeetrix.css",
    "./tokens.css": "./dist/qeetrix.tokens.css",
    "./tokens.json": "./dist/qeetrix.tokens.json"
  },
  "scripts": {
    "build": "node build.mjs",
    "validate": "node scripts/validate-contrast.mjs",
    "lint": "eslint .",
    "clean": "rm -rf dist build"
  },
  "devDependencies": {
    "@qeetrix/eslint-config": "workspace:*",
    "style-dictionary": "catalog:",
    "culori": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
