{
  "name": "@qeetix/tokens",
  "version": "0.0.1",
  "private": false,
  "description": "Qeetix design tokens — single W3C source built to CSS + JSON via Style Dictionary.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": ["*.css"],
  "files": ["dist"],
  "exports": {
    "./qeetix.css": "./dist/qeetix.css",
    "./tokens.css": "./dist/qeetix.tokens.css",
    "./tokens.json": "./dist/qeetix.tokens.json"
  },
  "scripts": {
    "build": "node build.mjs",
    "validate": "node scripts/validate-contrast.mjs",
    "lint": "eslint .",
    "clean": "rm -rf dist build"
  },
  "devDependencies": {
    "@qeetix/eslint-config": "workspace:*",
    "style-dictionary": "catalog:",
    "culori": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
