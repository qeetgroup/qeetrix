{
  "font": {
    "family": {
      "sans": {
        "$value": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
        "$type": "fontFamily"
      },
      "heading": {
        "$value": "\"Cal Sans Display\", ui-sans-serif, system-ui, sans-serif",
        "$type": "fontFamily"
      },
      "mono": {
        "$value": "ui-monospace, SFMono-Regular, \"SF Mono\", Menlo, Consolas, \"Liberation Mono\", monospace",
        "$type": "fontFamily"
      }
    },
    "line-height": {
      "none": { "$value": "1", "$type": "number" },
      "tight": { "$value": "1.2", "$type": "number" },
      "snug": { "$value": "1.35", "$type": "number" },
      "normal": { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.65", "$type": "number" }
    },
    "letter-spacing": {
      "tighter": { "$value": "-0.04em", "$type": "dimension" },
      "tight": { "$value": "-0.02em", "$type": "dimension" },
      "normal": { "$value": "0em", "$type": "dimension" },
      "wide": { "$value": "0.02em", "$type": "dimension" },
      "wider": { "$value": "0.04em", "$type": "dimension" }
    }
  }
}
