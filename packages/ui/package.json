{
  "name": "@qeetrix/ui",
  "version": "0.3.3",
  "private": false,
  "description": "Qeetrix UI — the Qeet Group React component library (shadcn + Base UI, Tailwind v4).",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./qeetrix.css": "./dist/styles/tokens.css",
    "./tokens.css": "./dist/styles/tokens.raw.css",
    "./tokens.json": "./dist/styles/tokens.json",
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "import": "./dist/brand/index.js",
      "default": "./dist/brand/index.js"
    },
    "./blocks": {
      "types": "./dist/blocks/index.d.ts",
      "import": "./dist/blocks/index.js",
      "default": "./dist/blocks/index.js"
    },
    "./blocks/*": {
      "types": "./dist/blocks/*.d.ts",
      "import": "./dist/blocks/*.js",
      "default": "./dist/blocks/*.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "default": "./dist/components/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js",
      "default": "./dist/hooks/*.js"
    },
    "./fonts/*": "./dist/fonts/*"
  },
  "scripts": {
    "build": "node scripts/build-tokens.mjs && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/postbuild.mjs",
    "build-tokens": "node scripts/build-tokens.mjs",
    "validate-tokens": "node scripts/build-tokens.mjs && node scripts/validate-contrast.mjs",
    "generate-logos": "node scripts/generate-logos.mjs",
    "dev": "node scripts/build-tokens.mjs && tsc -p tsconfig.build.json --watch --noEmit",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist build src/styles .turbo"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "@tiptap/pm": "catalog:",
    "@tiptap/react": "catalog:",
    "@tiptap/starter-kit": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "embla-carousel-react": "catalog:",
    "lucide-react": "catalog:",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "catalog:",
    "recharts": "catalog:",
    "shadcn": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@qeetrix/eslint-config": "workspace:*",
    "@qeetrix/tsconfig": "workspace:*",
    "culori": "catalog:",
    "style-dictionary": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "axe-core": "catalog:",
    "jsdom": "catalog:",
    "tailwindcss": "catalog:",
    "tsc-alias": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-axe": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
