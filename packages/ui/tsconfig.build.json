{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@qeetrix/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": { "@/*": ["./src/*"] },
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["src/stories/**", "**/*.stories.tsx"],
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}
